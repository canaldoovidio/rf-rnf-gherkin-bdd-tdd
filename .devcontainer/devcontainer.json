{
  "name": "RF-RNF Gherkin BDD TDD",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "python -m venv venv && . venv/bin/activate && pip install --upgrade pip && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "alexkrechik.cucumberautocomplete"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "cucumberautocomplete.steps": ["features/steps/*.py"],
        "cucumberautocomplete.syncfeatures": "features/*.feature"
      }
    }
  },
  "forwardPorts": [5000, 8089]
}
